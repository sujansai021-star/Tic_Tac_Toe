#include <iostream>
using namespace std;

int main() {
    // Step 1: Create 3x3 board
    char board[3][3];

    // Step 2: Initialize board with '-'
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            board[i][j] = '-';
        }
    }

    // Step 3: Display the board
    cout << "Tic-Tac-Toe Board:\n\n";
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            cout << board[i][j] << " ";
        }
        cout << endl;
    }

    return 0;
}
